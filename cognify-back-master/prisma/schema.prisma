generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  CAREGIVER
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  role          Role            @default(USER)
  createdAt     DateTime        @default(now())

  healthData    HealthData[]
  predictions   AiPrediction[]
}

model HealthData {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  timestamp DateTime

  // ===== VITALS =====
  steps                Int?
  heartRateAvg         Int?
  hrvSdnnMs            Float?
  bloodOxygenAvg       Float?

  // ===== MOVEMENT =====
  gaitSpeedMs          Float?
  stepCadence          Int?
  walkingAsymmetry     Float?

  // ===== SLEEP =====
  totalSleepHours      Float?
  deepSleepHours       Float?
  remSleepHours        Float?
  latencyMinutes       Int?
  awakenings           Int?

  // ===== COGNITIVE PERFORMANCE =====
  reactionTimeMs       Int?
  memoryScore          Int?
  testType             String?

  createdAt DateTime @default(now())
}

model AiPrediction {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  cognitiveIndex            Int?
  healthStatus              String?
  statusColor               String?

  stabilityScore            Float?
  fatigueRisk               String?
  neuroDeclineProbability   Float?

  anomalies                 Json?
  aiInsights                Json?

  modelVersion              String?

  createdAt DateTime @default(now())
}